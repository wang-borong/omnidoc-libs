\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{omni-admonitions}[2026/07/14 v0.1 Portable OmniDoc admonitions]

\RequirePackage{xcolor}
\RequirePackage[most]{tcolorbox}

\definecolor{OmniHintInk}{HTML}{174C53}
\definecolor{OmniHintFrame}{HTML}{2A9D8F}
\definecolor{OmniHintBack}{HTML}{F2F9F8}
\definecolor{OmniHintAccent}{HTML}{D9A928}

\NewTColorBox{OmniHint}{m}{
  enhanced,
  breakable,
  colback=OmniHintBack,
  colframe=OmniHintFrame,
  colbacktitle=OmniHintFrame!12!white,
  coltitle=OmniHintInk,
  fonttitle=\sffamily\bfseries,
  title={#1},
  boxrule=0pt,
  leftrule=2.4pt,
  arc=1.4mm,
  left=4mm,
  right=4mm,
  top=2.5mm,
  bottom=2.8mm,
  before skip=3.5mm,
  after skip=4mm,
  attach boxed title to top left={xshift=3mm,yshift*=-1.5mm},
  boxed title style={
    boxrule=0pt,
    arc=1.2mm,
    left=2.2mm,
    right=2.2mm,
    top=0.8mm,
    bottom=0.8mm,
  },
  overlay unbroken and first={
    \fill[OmniHintAccent] ([xshift=-5mm,yshift=-4.4mm]frame.north east) circle (1.2mm);
  },
}

\endinput
